{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "ollama intel",
  "outputfilename": "ollama-intel",
  "assetdir": ".",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "icon": "build/windows/icon.ico",
  "windows": {
    "console": false
  },
  "window": {
    "width": 1200,
    "height": 800,
    "min_width": 800,
    "min_height": 600,
    "title": "Ollama Intel Optimized GUI",
    "always_on_top": false,
    "resizable": true,
    "disable_minimise": false,
    "disable_maximise": false,
    "fullscreen": false,
    "start_hidden": false,
    "start_centered": true
  },
  "author": {
    "name": "User Name",
    "email": "user@example.com"
  },
  "nsis": {
    "installerIcon": "build/windows/icon.ico",
    "uninstallerIcon": "build/windows/icon.ico"
  }
}